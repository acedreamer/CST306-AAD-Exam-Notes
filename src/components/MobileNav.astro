---
import { getCollection, render } from 'astro:content';

const allModules = await getCollection('modules');
const sortedModules = allModules.sort((a, b) => a.data.order - b.data.order);

// Flatten the hierarchy into a linear sequence of topics
const navigationSequence = [];
navigationSequence.push({ label: 'HOME', url: `${import.meta.env.BASE_URL}/` });
navigationSequence.push({ label: 'CONTENTS', url: `${import.meta.env.BASE_URL}/contents` });

for (const module of sortedModules) {
  const rendered = await render(module);
  const topics = rendered.headings.filter((h) => h.depth === 2);
  
  // Add each topic as a navigation point
  for (const topic of topics) {
    navigationSequence.push({
      label: topic.text,
      url: `${import.meta.env.BASE_URL}/modules/${module.id}#${topic.slug}`
    });
  }
}

const currentPath = Astro.url.pathname;
const currentHash = Astro.url.hash;
const currentFullUrl = currentPath + currentHash;

// Logic to find current index in the sequence
const currentIndex = navigationSequence.findIndex(item => {
  const itemUrl = item.url;
  // Exact match for path+hash
  if (itemUrl === currentFullUrl) return true;
  // Fallback match for path only (if no hash)
  if (!currentHash && itemUrl.split('#')[0] === currentPath) return true;
  return false;
});

const prevItem = currentIndex > 0 ? navigationSequence[currentIndex - 1] : null;
const nextItem = currentIndex < navigationSequence.length - 1 ? navigationSequence[currentIndex + 1] : null;

// Determine if we are on the contents page to style the Index button
const isContentsPage = currentPath.endsWith('/contents') || currentPath.endsWith('/contents/');
---

<nav class="mobile-nav">
  <div class="nav-container">
    {prevItem ? (
      <a href={prevItem.url} class="nav-btn">
        <span class="btn-text">[PREV]</span>
      </a>
    ) : (
      <div class="nav-btn disabled">
        <span class="btn-text">[PREV]</span>
      </div>
    )}
    
    <a href={`${import.meta.env.BASE_URL}/contents`} class={`nav-btn index-btn ${isContentsPage ? 'active' : ''}`}>
      <span class="btn-text">[INDEX]</span>
    </a>

    {nextItem ? (
      <a href={nextItem.url} class="nav-btn">
        <span class="btn-text">[NEXT]</span>
      </a>
    ) : (
      <div class="nav-btn disabled">
        <span class="btn-text">[NEXT]</span>
      </div>
    )}
  </div>
</nav>

<style>
  .mobile-nav {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: var(--bg-deep);
    border-top: 2px solid var(--accent-green);
    z-index: 1000;
    padding-bottom: env(safe-area-inset-bottom);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .nav-btn {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0.85rem;
    text-decoration: none;
    color: var(--accent-green);
    font-family: var(--font-mono);
    font-weight: bold;
    font-size: 0.75rem;
    border: 1px solid var(--accent-green);
    margin: 0 0.25rem;
    background-color: var(--surface);
    transition: all 0.1s ease;
    text-transform: uppercase;
    box-shadow: 2px 2px 0px var(--accent-green);
    text-align: center;
  }

  .nav-btn:active:not(.disabled) {
    background-color: var(--accent-green);
    color: var(--bg-deep);
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px var(--accent-green);
  }

  .nav-btn.disabled {
    opacity: 0.3;
    cursor: not-allowed;
    border-color: var(--text-muted);
    color: var(--text-muted);
    box-shadow: none;
  }

  .index-btn {
    border-width: 2px;
    background-color: var(--bg-deep);
    color: var(--accent-amber);
    border-color: var(--accent-amber);
    box-shadow: 2px 2px 0px var(--accent-amber);
  }

  .index-btn.active {
    background-color: var(--accent-amber);
    color: var(--bg-deep);
    box-shadow: inset 2px 2px 4px rgba(0,0,0,0.5);
  }

  @media (max-width: 768px) {
    .mobile-nav {
      display: block;
    }
  }
</style>
