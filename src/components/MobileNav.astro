---
import { getCollection } from 'astro:content';

const allModules = await getCollection('modules');
const sortedModules = allModules.sort((a, b) => a.data.order - b.data.order);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname.replace(/\/$/, "");

// Define the global sequence of pages
const pageSequence = [
  { id: 'home', url: base || "/" },
  { id: 'contents', url: `${base}/contents` },
  ...sortedModules.map(m => ({ id: m.id, url: `${base}/modules/${m.id}` }))
];

const currentIndex = pageSequence.findIndex(p => p.url === currentPath);
const prevPage = currentIndex > 0 ? pageSequence[currentIndex - 1] : null;
const nextPage = currentIndex < pageSequence.length - 1 ? pageSequence[currentIndex + 1] : null;

const isContentsPage = currentPath.endsWith('/contents');
---

<nav class="mobile-nav" data-current-index={currentIndex}>
  <div class="nav-container">
    <a href={prevPage?.url} class={`nav-btn ${!prevPage ? 'disabled' : ''}`} id="mobile-prev">
      <span class="btn-text">[PREV]</span>
    </a>
    
    <a href={`${base}/contents`} class={`nav-btn index-btn ${isContentsPage ? 'active' : ''}`}>
      <span class="btn-text">[INDEX]</span>
    </a>

    <a href={nextPage?.url} class={`nav-btn ${!nextPage ? 'disabled' : ''}`} id="mobile-next">
      <span class="btn-text">[NEXT]</span>
    </a>
  </div>
</nav>

<script>
  /**
   * INTERACTIVE MOBILE NAVIGATION ENGINE
   * This script tracks the current scroll position and updates the 
   * [NEXT] and [PREV] buttons to move granularly through topics.
   */
  
  function initNav() {
    const nextBtn = document.getElementById('mobile-next') as HTMLAnchorElement;
    const prevBtn = document.getElementById('mobile-prev') as HTMLAnchorElement;
    if (!nextBtn || !prevBtn) return;

    // Get all topic headers on the current page
    const topics = Array.from(document.querySelectorAll('.prose h2[id]'));
    if (topics.length === 0) return;

    const topicIds = topics.map(t => t.id);
    const baseUrl = window.location.pathname;

    function updateButtons() {
      // Find which topic is currently in view
      let currentTopicIndex = -1;
      
      // We look for the first topic that is near the top of the viewport
      for (let i = 0; i < topics.length; i++) {
        const rect = topics[i].getBoundingClientRect();
        if (rect.top <= 150) { // Threshold for being "at the top"
          currentTopicIndex = i;
        }
      }

      // 1. Update NEXT Button
      if (currentTopicIndex < topics.length - 1) {
        // There is a next topic on this same page
        const nextTopicId = topicIds[currentTopicIndex + 1];
        nextBtn.href = `${baseUrl}#${nextTopicId}`;
      } else {
        // We are at the last topic, NEXT goes to the next Module (handled by server-side default)
      }

      // 2. Update PREV Button
      if (currentTopicIndex > 0) {
        // There is a previous topic on this same page
        const prevTopicId = topicIds[currentTopicIndex - 1];
        prevBtn.href = `${baseUrl}#${prevTopicId}`;
        prevBtn.classList.remove('disabled');
      } else if (currentTopicIndex === 0) {
        // We are at the first topic, PREV goes to Contents/Home (handled by server-side default)
      }
    }

    // Listen for scroll events to update button targets
    window.addEventListener('scroll', () => {
      // Use requestAnimationFrame for performance
      window.requestAnimationFrame(updateButtons);
    }, { passive: true });

    // Initial check
    updateButtons();
  }

  // Run on load and on Astro page transitions
  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>

<style>
  .mobile-nav {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: var(--bg-deep);
    border-top: 2px solid var(--accent-green);
    z-index: 1000;
    padding-bottom: env(safe-area-inset-bottom);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .nav-btn {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0.85rem;
    text-decoration: none;
    color: var(--accent-green);
    font-family: var(--font-mono);
    font-weight: bold;
    font-size: 0.75rem;
    border: 1px solid var(--accent-green);
    margin: 0 0.25rem;
    background-color: var(--surface);
    transition: all 0.1s ease;
    text-transform: uppercase;
    box-shadow: 2px 2px 0px var(--accent-green);
    text-align: center;
  }

  .nav-btn:active:not(.disabled) {
    background-color: var(--accent-green);
    color: var(--bg-deep);
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px var(--accent-green);
  }

  .nav-btn.disabled {
    opacity: 0.3;
    pointer-events: none;
    border-color: var(--text-muted);
    color: var(--text-muted);
    box-shadow: none;
  }

  .index-btn {
    border-width: 2px;
    background-color: var(--bg-deep);
    color: var(--accent-amber);
    border-color: var(--accent-amber);
    box-shadow: 2px 2px 0px var(--accent-amber);
  }

  .index-btn.active {
    background-color: var(--accent-amber);
    color: var(--bg-deep);
    box-shadow: inset 2px 2px 4px rgba(0,0,0,0.5);
  }

  @media (max-width: 768px) {
    .mobile-nav {
      display: block;
    }
  }
</style>
