    background-color: rgba(0, 255, 65, 0.08);
    font-weight: bold;
  }

  .sidebar {
    width: 280px;
    height: 100vh;
    background-color: var(--surface);
    border-right: var(--border-sharp);
    position: fixed;
    top: 0;
    left: 0;
    display: flex;
    flex-direction: column;
    z-index: 100;
  }

  .sidebar-header {
    padding: 1.5rem;
    border-bottom: var(--border-sharp);
    background-color: var(--bg-deep);
  }

  .brand {
    font-family: var(--font-mono);
    color: var(--accent-green);
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .file-explorer {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem 0;
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    padding: 0 1.5rem 0.5rem;
    letter-spacing: 0.1em;
  }

  .file-explorer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-link {
    display: flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    border-bottom: 1px solid transparent;
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    background-color: var(--bg-deep);
    color: var(--accent-amber);
    padding-left: 1.75rem;
  }

  .icon {
    margin-right: 0.75rem;
    color: var(--accent-green);
    font-weight: bold;
  }

  .topic-list {
    padding-bottom: 0.5rem;
  }

  .topic-link {
    display: flex;
    align-items: center;
    padding: 0.4rem 1.5rem 0.4rem 2.75rem;
    text-decoration: none;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    transition: all 0.2s ease;
  }

  .topic-link:hover {
    color: var(--accent-green);
    background-color: rgba(0, 255, 65, 0.05);
  }

  .topic-icon {
    margin-right: 0.5rem;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
