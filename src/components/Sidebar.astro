---
import { getCollection, render } from 'astro:content';

const allModules = await getCollection('modules');
const sortedModules = allModules.sort((a, b) => a.data.order - b.data.order);

// Pre-render all modules to get headings for nested navigation
const modulesWithHeadings = await Promise.all(
  sortedModules.map(async (module) => {
    const rendered = await render(module);
    const headings = rendered.headings;
    return {
      ...module,
      topics: headings.filter((h) => h.depth === 2),
    };
  })
);
---

<aside class="sidebar">
  <div class="sidebar-header">
    <span class="brand">ALGO_OS v1.0</span>
  </div>
  <nav class="file-explorer">
    <div class="section-title">DIRECTORY: /MODULES</div>
    <ul>
      {modulesWithHeadings.map(module => (
        <li class={`module-item ${module.id}`}>
          <a href={`${import.meta.env.BASE_URL}/modules/${module.id}`} class="nav-link" data-module-id={module.id}>
            <span class="icon">></span>
            <span class="label">{module.data.title}</span>
          </a>
          {module.topics.length > 0 && (
            <ul class="topic-list">
              {module.topics.map(topic => (
                <li>
                  <a href={`${import.meta.env.BASE_URL}/modules/${module.id}#${topic.slug}`} class="topic-link" data-topic-id={topic.slug}>
                    <span class="topic-icon">-</span>
                    <span class="topic-label">{topic.text}</span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </nav>
</aside>

<script>
  /**
   * PRECISION ACTIVE TOPIC HIGHLIGHTER
   */
  function initSidebarHighlight() {
    const currentPath = window.location.pathname;
    const sidebar = document.querySelector('.sidebar');
    if (!sidebar) return;

    const normalize = (path) => path.replace(/\/$/, "");
    const normalizedCurrent = normalize(currentPath);

    // 1. Highlight Active Module Link
    const moduleLinks = document.querySelectorAll('.nav-link');
    moduleLinks.forEach(link => {
      const href = link.getAttribute('href');
      if (href) {
        const normalizedHref = normalize(href.split('#')[0]);
        if (normalizedCurrent === normalizedHref) {
          link.classList.add('active-module');
        } else {
          link.classList.remove('active-module');
        }
      }
    });

    // 2. Precision ScrollSpy for Topics
    const topics = Array.from(document.querySelectorAll('.prose h2[id]'));
    const topicLinks = document.querySelectorAll('.topic-link');

    if (topics.length === 0) return;

    // Use a map for O(1) link lookup
    const idToLink = new Map();
    topicLinks.forEach(link => {
      const href = link.getAttribute('href');
      if (href && href.includes('#')) {
        const id = href.split('#')[1];
        idToLink.set(id, link);
      }
    });

    const observerOptions = {
      root: null,
      rootMargin: '-10% 0px -80% 0px', // Narrow strip at top-middle
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      // Sort entries by top position to handle simultaneous intersections
      const sortedEntries = entries
        .filter(e => e.isIntersecting)
        .sort((a, b) => a.target.getBoundingClientRect().top - b.target.getBoundingClientRect().top);

      if (sortedEntries.length > 0) {
        // The one closest to our top margin wins
        const activeId = sortedEntries[0].target.id;
        
        // Update visual states
        topicLinks.forEach(l => l.classList.remove('active-topic'));
        const activeLink = idToLink.get(activeId);
        if (activeLink) {
          activeLink.classList.add('active-topic');
        }
      }
    }, observerOptions);

    topics.forEach(t => observer.observe(t));
  }

  // Double-trigger for Astro's static generation and potential hydrations
  initSidebarHighlight();
  window.addEventListener('load', initSidebarHighlight);
  document.addEventListener('astro:after-swap', initSidebarHighlight);
</script>

<style>
